# =============================================================================
# INFRA DASHBOARD CONFIGURATION
# =============================================================================
# Copy to .env.local and fill in values

# -----------------------------------------------------------------------------
# COOLIFY INTEGRATION
# -----------------------------------------------------------------------------

# Coolify API endpoint
# Used for: fetching applications, triggering deploys, cancelling deployments
COOLIFY_API_URL=https://coolify.example.com/api/v1

# Coolify API token
# Generate in Coolify UI: Settings > API Tokens
# Required permissions: read applications, manage deployments
COOLIFY_API_TOKEN=

# Coolify PostgreSQL database connection
# Used for: real-time deployment tracking (faster than API polling)
# When running in Coolify: use container name 'coolify-db' (same Docker network)
# Format: postgresql://user:password@host:port/database
COOLIFY_DB_URL=

# Optional operator-facing topology shown on the Coolify dashboard.
# The build-server and per-server build caps are read from Coolify DB directly;
# these values describe the Coolify control-plane worker pool and registry host.
COOLIFY_DEPLOYMENT_WORKERS_MIN=6
COOLIFY_DEPLOYMENT_WORKERS_MAX=6
COOLIFY_REGISTRY_HOST=apps-vps
COOLIFY_REGISTRY_URL=apps-vps.tail0e7402.ts.net:5443

# -----------------------------------------------------------------------------
# PROMETHEUS (Metrics Collection)
# -----------------------------------------------------------------------------

# Prometheus server URL
# Scrapes: node_exporter (system metrics), postgres_exporter, pgbouncer_exporter
PROMETHEUS_URL=http://prometheus.example.com:9090

# node_exporter instances (format: "hostname:port")
VPS_PRIMARY_INSTANCE=app-server.example.com:9100
VPS_DATABASE_INSTANCE=db-server.example.com:9100

# -----------------------------------------------------------------------------
# REDIS / BULLMQ
# -----------------------------------------------------------------------------

# Redis connection
# Used for: BullMQ queue monitoring, AutoHEAL configuration storage
# REDIS_URL=redis://user:password@redis.example.com:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Redis password (required if Redis AUTH is enabled)
REDIS_PASSWORD=

# Redis username (optional, for ACL-based authentication)
# REDIS_USERNAME=

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------

# Dashboard password (optional)
# If set: users must authenticate to access the dashboard
# If empty: dashboard is publicly accessible (not recommended for production)
# Sessions are stored as httpOnly cookies, valid for 7 days
DASHBOARD_PASSWORD=

# -----------------------------------------------------------------------------
# SELF METRICS (optional)
# -----------------------------------------------------------------------------
#
# If set, `GET /metrics` requires either:
# - `Authorization: Bearer <token>`
# - `x-metrics-token: <token>`
#
METRICS_TOKEN=

# -----------------------------------------------------------------------------
# UPTIME KUMA (optional)
# -----------------------------------------------------------------------------

UPTIME_KUMA_URL=http://uptime-kuma.example.com:3001
UPTIME_KUMA_STATUS_PAGE=main

# -----------------------------------------------------------------------------
# WORKER SUPERVISOR (optional)
# -----------------------------------------------------------------------------

# Max age in seconds before worker supervisor payload is marked stale
WORKER_STATUS_MAX_AGE_SEC=180

# -----------------------------------------------------------------------------
# SITE HEALTH (optional)
# -----------------------------------------------------------------------------

# Comma-separated list of application names or domains to exclude from checks
SITE_HEALTH_EXCLUSIONS=

# -----------------------------------------------------------------------------
# HOME NETWORK MONITORING (optional)
# -----------------------------------------------------------------------------

# Token expected by POST /api/home-network/ingest.
# Store the live value in Bitwarden as:
# {{BWS:Infrastructure/HOME_NETWORK_DASHBOARD_INGEST_TOKEN}}
HOME_NETWORK_INGEST_TOKEN=

# Max snapshot age before /api/home-network reports warning.
HOME_NETWORK_MAX_AGE_SEC=180

# Max snapshot age accepted by ingest. This guards accidental replay.
HOME_NETWORK_INGEST_REJECT_AGE_SEC=3600

# Redis history length for compact minute samples.
HOME_NETWORK_HISTORY_LIMIT=1440

# -----------------------------------------------------------------------------
# HOME ACTIVITY LOGGING (optional)
# -----------------------------------------------------------------------------

# Token expected by POST /api/home-network/activity-events.
# Defaults to HOME_NETWORK_INGEST_TOKEN if omitted.
HOME_ACTIVITY_INGEST_TOKEN=

# PostgreSQL database used for endpoint activity events.
# Defaults to NEXTDNS_LOG_DB_URL or DATABASE_URL if omitted.
HOME_ACTIVITY_DB_URL=

# Full ingest URL used by scripts/collect-windows-browser-history.py.
# Example: https://infra.example.com/api/home-network/activity-events
HOME_ACTIVITY_API_URL=

# Optional Host header for internal Tailnet/reverse-proxy routes.
HOME_ACTIVITY_HOST_HEADER=

# Set to 1 only for trusted internal routes with hostname/certificate mismatch.
HOME_ACTIVITY_INSECURE_TLS=0

# Browser history lookback for each collector run.
HOME_ACTIVITY_LOOKBACK_MINUTES=1440

# -----------------------------------------------------------------------------
# NEXTDNS LOG CAPTURE (optional)
# -----------------------------------------------------------------------------

# API key from the NextDNS account page. Store live values in Bitwarden.
NEXTDNS_API_KEY=

# Comma-separated NextDNS profile IDs to ingest, for example:
# 23b61e,43d9e6,25bae4
NEXTDNS_PROFILE_IDS=

# PostgreSQL database used for durable DNS log storage.
# Defaults to DATABASE_URL if omitted. Do not point this at Coolify's internal DB.
NEXTDNS_LOG_DB_URL=

# Collector behavior.
NEXTDNS_LOG_LOOKBACK_MINUTES=15
NEXTDNS_LOG_FETCH_LIMIT=1000
NEXTDNS_LOG_FETCH_MAX_PAGES=5
NEXTDNS_LOG_RETENTION_DAYS=30

# A device is alerted when it has no stored NextDNS logs newer than this age.
NEXTDNS_CHILD_DEVICE_MAX_SILENT_MINUTES=60

# JSON array of expected child devices. Match by NextDNS device_id or device_name.
# Example:
# NEXTDNS_EXPECTED_CHILD_DEVICES=[{"name":"Chloe Laptop","device_names":["CHLOE-LAPTOP"],"profile_ids":["43d9e6"],"max_silent_minutes":60}]
NEXTDNS_EXPECTED_CHILD_DEVICES=
