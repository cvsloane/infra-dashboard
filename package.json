{
  "name": "infra-dashboard",
  "version": "0.1.0",
  "description": "Real-time infrastructure monitoring dashboard for Coolify, BullMQ, PostgreSQL, and VPS servers",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cvsloane/infra-dashboard.git"
  },
  "homepage": "https://github.com/cvsloane/infra-dashboard",
  "bugs": {
    "url": "https://github.com/cvsloane/infra-dashboard/issues"
  },
  "author": "Chris Sloane",
  "keywords": [
    "coolify",
    "infrastructure",
    "monitoring",
    "dashboard",
    "bullmq",
    "postgresql",
    "prometheus",
    "devops",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "collect:nextdns": "tsx scripts/collect-nextdns-logs.ts --once",
    "collect:home-activity": "python3 scripts/collect-windows-browser-history.py",
    "screenshots": "npx tsx scripts/screenshots.ts"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.15",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.562.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    }
  }
}
